# THIS FILE IS GENERATED. DO NOT EDIT IT BY HAND.
# Regenerate it with: pnpm env:example
# Environment template for all.
# Sources of truth: packages/env/src/registry.ts and each scraper's environment declaration.
# Contains no secret values. Run pnpm env:setup to configure a value file.

# Database
# Postgres connection used by the API, auth, DB tools, and DB-writing scrapers. Percent-encode special characters only inside substituted username/password components.
# Get it: https://supabase.com/docs/guides/database/connecting-to-postgres
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Authentication
# High-entropy secret used to sign and encrypt Better Auth data.
# Get it: https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=

# Discord OAuth application client ID.
# Get it: https://discord.com/developers/applications
# AUTH_DISCORD_ID=

# Discord OAuth application client secret.
# Get it: https://discord.com/developers/applications
# AUTH_DISCORD_SECRET=

# Email
# Full-access Resend key for waitlist contacts and feedback email.
# Get it: https://resend.com/docs/dashboard/api-keys/introduction
# RESEND_API_KEY=

# Comma-separated inboxes that receive in-app feedback.
# FEEDBACK_TO_EMAIL=

# Verified Resend sender, for example Billion <feedback@example.com>.
# Get it: https://resend.com/docs/dashboard/domains/introduction
# FEEDBACK_FROM_EMAIL=

# Optional Resend segment assigned to waitlist contacts.
# Get it: https://resend.com/docs/dashboard/segments/introduction
# RESEND_WAITLIST_SEGMENT_ID=

# Optional Resend topic for launch-update consent.
# Get it: https://resend.com/docs/knowledge-base/why-use-topics
# RESEND_LAUNCH_UPDATES_TOPIC_ID=

# Expo
# Public HTTPS origin of the Next.js API; compiled into Expo builds.
# Get it: https://docs.expo.dev/eas/environment-variables/
EXPO_PUBLIC_API_URL=http://localhost:3000

# Civic data
# Google Civic Information API key for real ballot and representative data.
# Get it: https://developers.google.com/civic-information/docs/using_api
# GOOGLE_CIVIC_API_KEY=

# Dedicated Places API (New) key for production address autocomplete.
# Get it: https://developers.google.com/maps/documentation/places/web-service/cloud-setup
# GOOGLE_PLACES_API_KEY=

# Open States key for state bills, legislators, and voting records.
# Get it: https://openstates.org/accounts/profile/
# OPEN_STATES_API_KEY=

# Vote Smart key for candidate and state-measure enrichment.
# Get it: https://votesmart.org/share/api
# VOTE_SMART_API_KEY=

# AI
# DeepSeek key for AI text generation.
# Get it: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Fallback API-side AI key; not used by the scraper.
# Get it: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Scraper sources
# Congress.gov API key for federal bill ingestion.
# Get it: https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# CourtListener token for higher SCOTUS request limits.
# Get it: https://www.courtlistener.com/sign-in/
# COURTLISTENER_API_KEY=

# Scraper images
# Black Forest Labs key for generated feed-card images.
# Get it: https://docs.bfl.ai/quick_start/get_started
# BFL_API_KEY=

# BFL image model endpoint.
# BFL_MODEL=flux-2-pro

# Google images
# Google Custom Search key; also a fallback for Places.
# Get it: https://console.cloud.google.com/apis/credentials
# GOOGLE_API_KEY=

# Programmable Search Engine identifier used with GOOGLE_API_KEY.
# Get it: https://programmablesearchengine.google.com/
# GOOGLE_SEARCH_ENGINE_ID=

# Scraper vision
# Gemini vision fallback for PDF-heavy scraper sources.
# Get it: https://aistudio.google.com/app/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=

# Scraper operations
# Set to 1 only for a deliberate AI regeneration backfill.
# SCRAPER_FORCE_AI_REGEN=0

# Max brand-new items (per data source) that get AI enrichment in one run; extras roll over to the next run.
# SCRAPER_MAX_NEW_ITEMS_PER_RUN=10

# Scraper source limits
# Federal Register documents per run.
# FEDERALREGISTER_MAX_ITEMS=20

# Congress.gov bills per run.
# CONGRESS_MAX_ITEMS=100

# CourtListener opinion clusters per run.
# SCOTUS_MAX_ITEMS=50

# Santa Clara voter-guide PDFs per run.
# SCC_CVIG_MAX_ITEMS=10

# California SOS office pages per run.
# CA_SOS_MAX_ITEMS=9

# Scraper cost reporting
# Estimated LLM input price.
# LLM_INPUT_PRICE=0.10

# Estimated LLM output price.
# LLM_OUTPUT_PRICE=0.30

# Estimated price per generated BFL image.
# FLUX_IMAGE_PRICE=0.03

# Estimated price per Custom Search request.
# GOOGLE_SEARCH_PRICE=0.005

# Social media
# Web origin captured by the social-media agent.
# BASE_URL=http://localhost:8081

# Google AI Studio key for social caption generation.
# Get it: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# Instagram login used only by the posting workflow.
# INSTAGRAM_USERNAME=

# Instagram password used only by the posting workflow.
# INSTAGRAM_PASSWORD=
