{
  "name": "@acme/social-media-agent",
  "version": "0.0.1",
  "type": "module",
  "description": "Instagram content generation and posting automation for Billion",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "test": "playwright test",
    "agent:run": "tsx src/entry.ts run",
    "instagram": "tsx src/entry.ts instagram",
    "video": "tsx src/entry.ts video",
    "test:video": "tsx --test src/video/*.test.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "license": "MIT",
  "dependencies": {
    "@acme/env": "workspace:*",
    "@google/generative-ai": "^0.24.1",
    "commander": "^14.0.3",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
