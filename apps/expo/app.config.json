{
  "name": "billion",
  "slug": "billion",
  "scheme": "billion",
  "version": "0.1.2",
  "orientation": "portrait",
  "icon": "./assets/billion-logo.png",
  "userInterfaceStyle": "dark",
  "updates": {
    "fallbackToCacheTimeout": 0
  },
  "newArchEnabled": true,
  "assetBundlePatterns": [
    "**/*"
  ],
  "ios": {
    "bundleIdentifier": "app.billion-news.billion",
    "supportsTablet": true,
    "icon": {
      "light": "./assets/billion-logo.png",
      "dark": "./assets/billion-logo.png"
    },
    "infoPlist": {
      "ITSAppUsesNonExemptEncryption": false
    }
  },
  "android": {
    "package": "app.billionnews.billion",
    "adaptiveIcon": {
      "foregroundImage": "./assets/billion-logo.png",
      "backgroundColor": "#0E1530"
    },
    "edgeToEdgeEnabled": true
  },
  "extra": {
    "eas": {
      "projectId": "c38bc8f8-f82c-4a45-b819-d62bd366ac8b"
    }
  },
  "experiments": {
    "tsconfigPaths": true,
    "typedRoutes": true
  },
  "plugins": [
    "expo-router",
    "expo-secure-store",
    "expo-web-browser",
    [
      "expo-splash-screen",
      {
        "backgroundColor": "#0E1530",
        "image": "./assets/billion-logo.png",
        "dark": {
          "backgroundColor": "#0E1530",
          "image": "./assets/billion-logo.png"
        }
      }
    ]
  ]
}
