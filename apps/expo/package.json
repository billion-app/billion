    "@expo-google-fonts/inria-serif": "^0.4.1",
    "@expo/dom-webview": "^56.0.6",
    "@expo/metro-runtime": "^56.0.16",
    "@expo/vector-icons": "^15.1.1",
    "@legendapp/list": "^2.0.19",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@ronradtke/react-native-markdown-display": "^8.1.0",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "better-auth": "catalog:",
    "expo": "~56.0.15",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.22",
    "expo-constants": "~56.0.20",
    "expo-dev-client": "~56.0.22",
    "expo-font": "~56.0.7",
    "expo-image": "~56.0.11",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.15",
    "expo-network": "~56.0.5",
    "expo-router": "~56.2.14",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.21",
    "expo-web-browser": "~56.0.5",
    "fuse.js": "^7.1.0",
    "nativewind": "5.0.0-preview.3",
    "react": "19.2.3",
