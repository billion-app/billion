{
  "name": "@acme/expo",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules",
    "dev": "expo start",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit",
    "build:ios": "expo prebuild --platform ios --clean",
    "build:android": "expo prebuild --platform android --clean",
    "release": "node ../../scripts/release.mjs"
  },
  "dependencies": {
    "@acme/ui": "workspace:*",
    "@better-auth/expo": "catalog:",
    "@expo-google-fonts/albert-sans": "^0.4.2",
    "@expo-google-fonts/ibm-plex-serif": "^0.4.1",
    "@expo-google-fonts/inria-serif": "^0.4.1",
    "@expo/vector-icons": "^14.1.0",
    "@legendapp/list": "^2.0.19",
    "@ronradtke/react-native-markdown-display": "^8.1.0",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "better-auth": "catalog:",
    "expo": "~53.0.27",
    "expo-blur": "~14.1.5",
    "expo-build-properties": "~0.14.8",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.2",
    "expo-image": "~2.4.1",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-network": "~7.1.5",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.4",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.11",
    "expo-updates": "~0.28.18",
    "expo-web-browser": "~14.2.0",
    "fuse.js": "^7.1.0",
    "nativewind": "5.0.0-preview.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "~0.79.6",
    "react-native-css": "3.0.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.5",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-web": "~0.20.0",
    "superjson": "2.2.6"
  },
  "devDependencies": {
    "@acme/api": "workspace:*",
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tailwind-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@types/react": "^19.1.17",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "prettier": "@acme/prettier-config"
}
